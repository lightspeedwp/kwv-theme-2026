					"color": "#332A16"
				},
				{
					"name": "Brand 900",
					"slug": "brand-900",
					"color": "#0B0905"
				},
				{
					"name": "Error Foreground",
					"slug": "error-foreground",
					"color": "#F10E0E"
				},
				{
					"name": "Error Background",
					"slug": "error-background",
					"color": "#F10E0E1A"
				},
				{
					"name": "Warning Foreground",
					"slug": "warning-foreground",
					"color": "#F59E0B"
				},
				{
					"name": "Warning Background",
					"slug": "warning-background",
					"color": "#F59E0B1A"
				},
				{
					"name": "Information Foreground",
					"slug": "information-foreground",
					"color": "#3B82F6"
				},
				{
					"name": "Information Background",
					"slug": "information-background",
					"color": "#3B82F61A"
				},
				{
					"name": "Success Foreground",
					"slug": "success-foreground",
					"color": "#019733"
				},
				{
					"name": "Success Background",
					"slug": "success-background",
					"color": "#0197331A"
				}
			],
			"link": true
		},
		"custom": {
			"fontWeight": {
				"thin": 100,
				"extra-light": 200,
				"light": 300,
				"regular": 400,
				"medium": 500,
				"semi-bold": 600,
				"bold": 700,
				"extra-bold": 800,
				"black": 900
			},
			"lineHeight": {
				"snug": "1.125",
				"heading": "1.25",
				"button": "1.35",	
				"body": "1.5"
			},
			"letterSpacing": {
				"none": "0em",
				"narrow": "0.02em",
				"heading": "0.04em",
				"wide": "0.075em"
			},
			"spacing": {
				"button": {
					"padding-horizontal": "clamp(32px, 14vw, 48px)",
					"padding-vertical": "clamp(14px, 10vw, 18px)"
				}
			}
		},
		"layout": {
			"contentSize": "900px",
			"wideSize": "1520px"
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Tiny",
					"slug": "100",
					"shadow": "0 1px 2px 0 rgba(17, 17, 17, 0.2)"
				},
				{
					"name": "Base",
					"slug": "200",
					"shadow": "0 2px 4px 0 rgba(17, 17, 17, 0.22)"
				},
				{
					"name": "Small",
					"slug": "300",
					"shadow": "0 4px 8px 0 rgba(17, 17, 17, 0.24)"
				},
				{
					"name": "Medium",
					"slug": "400",
					"shadow": "0 6px 12px 0 rgba(17, 17, 17, 0.26)"
				},
				{
					"name": "Large",
					"slug": "500",
					"shadow": "0 10px 20px 0 rgba(17, 17, 17, 0.28)"
				},
				{
					"name": "X-Large",
					"slug": "600",
					"shadow": "0 16px 32px 0 rgba(17, 17, 17, 0.3)"
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "XXS",
					"size": "clamp(0.25rem, calc(0.227rem + 0.006vw), 0.313rem)",
					"slug": "5"
				},
				{
					"name": "XS",
					"size": "clamp(0.5rem, calc(0.454rem + 0.012vw), 0.625rem)",
					"slug": "10"
				},
				{
					"name": "S",
					"size": "clamp(0.875rem, calc(0.736rem + 0.036vw), 1.25rem)",
					"slug": "20"
				},
				{
					"name": "M",
					"size": "clamp(1.25rem, calc(1.018rem + 0.06vw), 1.875rem)",
					"slug": "30"
				},
				{
					"name": "L",
					"size": "clamp(1.625rem, calc(1.3rem + 0.083vw), 2.5rem)",
					"slug": "40"
				},
				{
					"name": "XL",
					"size": "clamp(2.063rem, calc(1.668rem + 0.101vw), 3.125rem)",
					"slug": "50"
				},
				{
					"name": "XXL",
					"size": "clamp(2.313rem, calc(1.779rem + 0.137vw), 3.75rem)",
					"slug": "60"
				},
				{
					"name": "XXXL",
					"size": "clamp(2.625rem, calc(1.975rem + 0.167vw), 4.375rem)",
					"slug": "70"
				},
				{
					"name": "XXXXL",
					"size": "clamp(3rem, calc(2.257rem + 0.19vw), 5rem)",
					"slug": "80"
				},
				{
					"name": "Gigantic",
					"size": "clamp(3.5rem, calc(2.711rem + 0.202vw), 5.625rem)",
					"slug": "90"
				},
				{
					"name": "Colossal",
					"size": "clamp(4rem, calc(3.164rem + 0.214vw), 6.25rem)",
					"slug": "100"
				}
			],
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			],
			"blockGap": true,
			"padding": true,
			"margin": true
		},
		"typography": {
			"dropCap": false,
			"defaultFontSizes": false,
			"fluid": true,
			"writingMode": true,
			"fontFamilies": [
				{
					"fontFamily": "Poppins, sans-serif",
					"name": "Poppins",
					"slug": "heading",
					"fontFace": [
						{
							"fontDisplay": "swap",
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "100",
							"src": [
								"file:./assets/fonts/poppins/Poppins-100-normal.woff2"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "200",
							"src": [
								"file:./assets/fonts/poppins/Poppins-200-normal.woff2"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [
								"file:./assets/fonts/poppins/Poppins-300-normal.woff2"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/poppins/Poppins-400-normal.woff2"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/poppins/Poppins-500-normal.woff2"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/poppins/Poppins-600-normal.woff2"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/poppins/Poppins-700-normal.woff2"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "800",
							"src": [
								"file:./assets/fonts/poppins/Poppins-800-normal.woff2"
							]
						},
						{
							"fontDisplay": "swap",
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "900",
							"src": [
								"file:./assets/fonts/poppins/Poppins-900-normal.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Poppins, sans-serif",
					"name": "Poppins",
					"slug": "body"
				},
				{
					"fontFamily": "\"Bodoni Moda\", serif",
					"name": "Bodoni Moda",
					"slug": "accent",
					"fontFace": [
						{
							"fontDisplay": "swap",
							"fontFamily": "Bodoni Moda",
							"fontStyle": "normal",
							"fontWeight": "400 900",
							"src": [
								"file:./assets/fonts/bodoni-moda/BodoniModa-VariableFont_wght.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "monospace",
					"name": "Monospace",
					"slug": "monospace"
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"min": "0.688rem",
						"max": "0.75rem"
					},
					"size": "0.75rem",
					"slug": "100",
					"name": "Tiny"
				},
				{
					"fluid": {
						"min": "0.875rem",
						"max": "1rem"
					},
					"size": "1rem",
					"slug": "200",
					"name": "Base"
				},
				{
					"fluid": {
						"min": "1rem",
						"max": "1.20rem"
					},
					"size": "1.20rem",
					"slug": "300",
					"name": "Small"
				},
				{
					"fluid": {
						"min": "1.25rem",
						"max": "1.5rem"
					},
					"size": "1.5rem",
					"slug": "400",
					"name": "Medium"
				},
				{
					"fluid": {
						"min": "1.625rem",
						"max": "2rem"
					},
					"size": "2rem",
					"slug": "500",
					"name": "Large"
				},
				{
					"fluid": {
						"min": "2.125rem",
						"max": "2.5rem"
					},
					"size": "2.5rem",
					"slug": "600",
					"name": "X-Large"
				},
				{
					"fluid": {
						"min": "2.375rem",
						"max": "3rem"
					},
					"size": "3rem",
					"slug": "700",
					"name": "Huge"
				},
				{
					"fluid": {
						"min": "2.625rem",
						"max": "4rem"
					},
					"size": "4rem",
					"slug": "800",
					"name": "Gigantic"
				},
				{
					"fluid": {
						"min": "3rem",
						"max": "5rem"
					},
					"size": "5rem",
					"slug": "900",
					"name": "Colossal"
				}
			],
			"lineHeight": true
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/button": {
				"variations": {
					"outline": {
						"spacing": {
							"padding": {
								"top": "var:custom|spacing|button|padding-vertical",
								"right": "var:custom|spacing|button|padding-horizontal",
								"bottom": "var:custom|spacing|button|padding-vertical",
								"left": "var:custom|spacing|button|padding-horizontal"
							}
						},
						"typography": {
							"fontSize": "var:preset|font-size|300",
							"fontWeight": "var:custom|font-weight|medium",
							"textTransform": "uppercase",
							"letterSpacing": "var:custom|letter-spacing|wide"
						},
						"color": {
							"background": "var:preset|color|contrast",
							"text": "var:preset|color|base",
							"border": "1px solid var:preset|color|base"
						},
						":hover": {
							"color": {
								"background": "var:preset|color|base",
								"text": "var:preset|color|contrast",
								"border": "1px solid var:preset|color|base"
							}
						}
					}
				}
			},
			"core/code": {
				"border": {
					"radius": "5px",
					"width": "0px"
				},
				"color": {
					"background": "var:preset|color|neutral-200",
					"text": "var:preset|color|contrast"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|30",
						"right": "var:preset|spacing|30",
						"bottom": "var:preset|spacing|30",
						"left": "var:preset|spacing|30"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|monospace",
					"fontSize": "var:preset|font-size|200"
				}
			},
			"core/comment-author-name": {
				"typography": {
					"lineHeight": "var:custom|line-height|body",
					"fontWeight": "600"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none",
							"fontSize": "var:preset|font-size|200"
						}
					}
				}
			},
			"core/comment-content": {
				"spacing": {
					"margin": {
						"top": "20px !important"
					}
				}
			},
			"core/comment-date": {
				"typography": {
					"fontSize": "var:preset|font-size|200",
					"lineHeight": "var:custom|line-height|body"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/comment-edit-link": {
				"typography": {
					"fontSize": "var:preset|font-size|200",
					"lineHeight": "var:custom|line-height|body"
				}
			},
			"core/comment-reply-link": {
				"typography": {
					"fontSize": "var:preset|font-size|200"
				}
			},
			"core/comments-title": {
				"spacing": {
					"margin": {
						"top": "0px",
						"bottom": "var:preset|spacing|40"
					}
				}
			},
			"core/post-comments-form": {
				"typography": {
					"fontSize": "var:preset|font-size|200"
				},
				"elements": {
					"button": {
						"typography": {
							"fontSize": "var:preset|font-size|200"
						}
					}
				},
				"css": "& .comment-reply-title { font-size: var(--wp--preset--font-size--300) }"
			},
			"core/details": {
				"css": ".wp-block-details summary { font-weight: 600 }"
			},
			"core/read-more": {
				"elements": {
					"link": {
						"spacing": {
							"margin": {
								"top": "20px",
								"bottom": "20px"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontWeight": "500"
				},
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/paragraph": {
				"css": "&.has-background { padding: var(--wp--preset--spacing--20) }"
			},
			"core/post-template": {
				"elements": {
					"h2": {
						"typography": {
							"fontSize": "var:preset|font-size|400"
						}
					}
				},
				"css": "& li:last-child:not(:only-child) > .wp-block-separator:last-child { display: none; }"
			},
			"core/post-terms": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/preformatted": {
				"border": {
					"radius": "5px"
				},
				"color": {
					"background": "var:preset|color|neutral-200",
					"text": "var:preset|color|contrast"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|30",
						"right": "var:preset|spacing|30",
						"bottom": "var:preset|spacing|30",
						"left": "var:preset|spacing|30"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|monospace",
					"fontSize": "var:preset|font-size|200"
				}
			},
			"core/pullquote": {
				"elements": {
					"cite": {
						"typography": {
							"fontSize": "var:preset|font-size|200"
						},
						"color": {
							"text": "var:preset|color|neutral-700"
						}
					}
				},
				"border": {
					"color": "var:preset|color|brand-500",
					"top": {
						"style": "solid",
						"width": "5px"
					}
				},
				"spacing": {
					"padding": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					}
				},
				"typography": {
					"lineHeight": "var:custom|line-height|body",
					"fontSize": "var:preset|font-size|400",
					"fontWeight": "500"
				}
			},
			"core/query-pagination": {
				"spacing": {
					"blockGap": "var:preset|spacing|20"
				},
				"elements": {
					"link": {
						"border": {
							"radius": "0",
							"width": "0"
						},
						"color": {
							"background": "transparent !important",
							"text": "var:preset|color|neutral-700"
						},
						"spacing": {
							"padding": {
								"top": "var:preset|spacing|10",
								"right": "var:preset|spacing|20",
								"bottom": "var:preset|spacing|10",
								"left": "var:preset|spacing|20"
							}
						},
						"typography": {
							"fontSize": "var:preset|font-size|300",
							"fontWeight": "var:custom|font-weight|medium",
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|brand-600",
								"background": "transparent !important"
							},
							"typography": {
