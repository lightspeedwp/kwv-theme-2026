# KWV E2E — environment contract. Copy to `.env` and fill locally. NEVER commit `.env`.
# All values are read by playwright.config.ts / the specs. Use test data only.

# Base URL of the target environment (staging/preview — never production for stateful flows)
KWV_BASE_URL=https://kwv.lightspeedwp.dev

# --- Sandbox / stateful gating -------------------------------------------------
# Set to "1" ONLY when the gateway is in sandbox/test mode AND a test card exists.
# @stateful (order-placing) cases skip unless this is "1".
KWV_SANDBOX=0

# Gateway sandbox test card (test PAN only — never a real card). Leave blank until provided.
KWV_TEST_CARD_NUMBER=
KWV_TEST_CARD_EXPIRY=
KWV_TEST_CARD_CVV=

# --- Test customer (for logged-in checkout) ------------------------------------
# Dedicated test account only — never a real customer. Leave blank until provided.
KWV_TEST_CUSTOMER_EMAIL=
KWV_TEST_CUSTOMER_PASSWORD=

# --- Test data -----------------------------------------------------------------
# Seeded product used by cart/checkout cases (slug + display name + price string).
KWV_PRODUCT_SLUG=kwv-classic-chardonnay-2025
KWV_PRODUCT_NAME=KWV Classic Chardonnay 2025

# Known test coupon for the discount case. Confirm validity + cart threshold before enabling.
# (Candidate PINOTAGE100 = 15% off orders over R500.)
KWV_COUPON_CODE=
