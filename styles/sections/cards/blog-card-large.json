{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "Blog Card Large",
	"slug": "blog-card-large",
	"blockTypes": [ "core/group" ],
	"styles": {
		"css": "&{position:relative}& .blog-card-large__media{position:relative}& .blog-card-large__media img{display:block;width:100%;object-fit:cover}& .wp-block-separator.kwv-rule-brand{width:16rem;max-width:100%;margin-left:0;margin-right:auto}& .wp-block-post-excerpt{text-align:justify}",
		"elements": {
			"link": {
				"color": {
					"text": "var:preset|color|contrast"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|brand-500"
					},
					"typography": {
						"textDecoration": "none"
					}
				}
			}
		},
		"blocks": {
			"core/post-featured-image": {
				"border": {
					"radius": "0"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var:preset|font-size|400",
					"fontWeight": "var:custom|font-weight|black",
					"textTransform": "uppercase"
				}
			}
		}
	}
}
