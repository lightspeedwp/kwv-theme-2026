{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "Blog Card",
	"slug": "blog-card",
	"blockTypes": [ "core/group" ],
	"styles": {
		"blocks": {
			"core/post-featured-image": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				},
				"border": {
					"radius": "0"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|contrast"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"typography": {
						"textDecoration": "none"
					},
					"color": {
						"text": "var:preset|color|brand-500"
					}
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--200)",
					"fontWeight": "var(--wp--custom--font-weight--medium)",
					"textTransform": "none"
				},
				"hover": {
					"color": "var:preset|color|brand-500",
					"textDecoration": "none"
				}
			}
		},
	
		"css": "&{transition:all 0.25s ease} &{position:relative}& .blog-card__media{position:relative;overflow:hidden;}& .blog-card__media .wp-block-post-featured-image{margin:0}& .blog-card__media img{display:block;width:100%;object-fit:cover}"
	}
}
