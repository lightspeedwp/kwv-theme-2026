{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "Product Card",
	"slug": "product-card",
	"blockTypes": [ "core/group" ],
	"description": "WooCommerce product card: white frame, gold brand border, packshot, divider, title, attribute and price.",
	"styles": {
		"border": {
			"color": "var:preset|color|brand-500",
			"style": "solid",
			"width": "1px",
			"radius": "var:preset|border-radius|200"
		},
		"color": {
			"background": "var:preset|color|base"
		},
		"spacing": {
			"blockGap": "var:preset|spacing|20",
			"margin": {
				"top": "0"
			},
			"padding": {
				"top": "var:preset|spacing|30",
				"right": "var:preset|spacing|30",
				"bottom": "var:preset|spacing|30",
				"left": "var:preset|spacing|30"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var:preset|color|contrast"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"typography": {
						"textDecoration": "none"
					}
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontSize": "var:preset|font-size|300",
					"fontWeight": "var:custom|font-weight|medium",
					"textTransform": "uppercase",
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|contrast"
					},
					"typography": {
						"textDecoration": "none"
					}
				}
			},
			"core/separator": {
				"color": {
					"background": "var:preset|color|brand-500"
				}
			},
			"woocommerce/product-title": {
				"typography": {
					"fontSize": "var:preset|font-size|300",
					"fontWeight": "var:custom|font-weight|medium",
					"textTransform": "uppercase",
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|contrast"
					},
					"typography": {
						"textDecoration": "none"
					}
				}
			}
		}
	}
}
