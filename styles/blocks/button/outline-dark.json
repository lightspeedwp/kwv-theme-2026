{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "Outline Dark",
	"slug": "outline-dark",
	"blockTypes": [ "core/button" ],
	"description": "Transparent button with a 1px contrast border and contrast text, square corners — the light-section counterpart to the base-on-dark outline variation. On hover the fill drops to contrast with base text.",
	"styles": {
		"color": {
			"background": "transparent",
			"text": "var:preset|color|contrast"
		},
		"border": {
			"color": "var:preset|color|contrast",
			"style": "solid",
			"width": "1px",
			"radius": "0"
		},
		"spacing": {
			"padding": {
				"top": "var:custom|spacing|button|padding-vertical",
				"right": "var:custom|spacing|button|padding-horizontal",
				"bottom": "var:custom|spacing|button|padding-vertical",
				"left": "var:custom|spacing|button|padding-horizontal"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|heading",
			"fontSize": "var:preset|font-size|200",
			"fontWeight": "var:custom|font-weight|semi-bold",
			"textTransform": "uppercase",
			"letterSpacing": "0.02em"
		},
		":hover": {
			"color": {
				"background": "var:preset|color|contrast",
				"text": "var:preset|color|base"
			},
			"border": {
				"color": "var:preset|color|contrast"
			}
		},
		":focus": {
			"color": {
				"background": "var:preset|color|contrast",
				"text": "var:preset|color|base"
			},
			"border": {
				"color": "var:preset|color|contrast"
			}
		}
	}
}
